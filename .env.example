OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
PUBLIC_DEMO_PROJECT_ID=ecosmart-demo

STORAGE_DRIVER=local_json

ENABLE_MOCK_SOURCE=true
ENABLE_MANUAL_SOURCE=true
ENABLE_EU_PORTAL_SOURCE=false
EU_PORTAL_API_BASE_URL=
EU_PORTAL_API_TIMEOUT_MS=10000

SUPABASE_URL=
# Use the same value as SUPABASE_URL. This is public Supabase project config, not a secret.
NEXT_PUBLIC_SUPABASE_URL=
# Use the Supabase anon/publishable key. Never use SUPABASE_SERVICE_ROLE_KEY here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Required only if enabling trusted production admin/import/export calls.
ADMIN_SECRET=
